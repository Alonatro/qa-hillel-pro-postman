        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let carId = pm.environment.get(\"carId\");\r",
              "let lastTotalCost = pm.environment.get(`lastTotalCost_${carId}`);\r",
              "let newTotalCost;\r",
              "\r",
              "if (lastTotalCost) {\r",
              "    newTotalCost = parseInt(lastTotalCost) + Math.floor(Math.random() * 20 + 1);\r",
              "} else {\r",
              "    newTotalCost = 50;\r",
              "}\r",
              "\r",
              "pm.environment.set(`lastTotalCost_${carId}`, newTotalCost);\r",
              "pm.environment.set(\"totalCost\", newTotalCost);\r",
              "\r",
              "let carCreationDate = pm.environment.get(\"carCreationDate\") || new Date().toISOString();\r",
              "let creation = new Date(carCreationDate);\r",
              "let today = new Date();\r",
              "if (creation > today) creation = today;\r",
              "\r",
              "let reportedAt = new Date(creation.getTime() + Math.random() * (today.getTime() - creation.getTime()));\r",
              "reportedAt = reportedAt.toISOString().split('T')[0];\r",
              "pm.environment.set(\"reportedAt\", reportedAt);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
