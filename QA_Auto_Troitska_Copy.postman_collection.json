    {
      "name": "Create a new user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let random = Math.floor(Math.random() * 100000);\r",
              "\r",
              "pm.environment.set(\"email\", \"test\" + random + \"@test.com\");\r",
              "pm.environment.set(\"password\", \"Qwerty12345\");\r",
              "\r",
              "let email = pm.environment.get(\"email\");\r",
              "let emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\r",
              "\r",
              "if (!emailRegex.test(email)) {\r",
              "    postman.setNextRequest(null);\r",
              "}\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"userId\", response.data.userId);\r",
              "pm.environment.set(\"photoFilename\", response.data.photoFilename);\r",
              "pm.environment.set(\"distanceUnits\", response.data.distanceUnits);\r",
              "pm.environment.set(\"currency\", response.data.currency);\r",
              "\r",
              "pm.environment.set(\"name\", pm.variables.get(\"{{$randomFirstName}}\"));\r",
              "pm.environment.set(\"lastName\", pm.variables.get(\"{{$randomLastName}}\"));\r",
              "\r",
              "pm.test(\"User created successfully\", function () {\r",
              "    pm.response.to.have.status(201); \r",
              "\r",
              "    pm.expect(response.data.userId).to.exist;\r",
              "});\r",
              "\r",
              "var schema = {\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"status\": {\r",
              "      \"type\": \"string\"\r",
              "    },\r",
              "    \"data\": {\r",
              "      \"type\": \"object\",\r",
              "      \"properties\": {\r",
              "        \"userId\": {\r",
              "          \"type\": \"integer\"\r",
              "        },\r",
              "        \"photoFilename\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"distanceUnits\": {\r",
              "          \"type\": \"string\"\r",
              "        },\r",
              "        \"currency\": {\r",
              "          \"type\": \"string\"\r",
              "        }\r",
              "      },\r",
              "      \"required\": [\r",
              "        \"userId\",\r",
              "        \"photoFilename\",\r",
              "        \"distanceUnits\",\r",
              "        \"currency\"\r",
              "      ]\r",
              "    }\r",
              "  },\r",
              "  \"required\": [\r",
              "    \"status\",\r",
              "    \"data\"\r",
              "  ]\r",
              "}\r",
              "\r",
              "pm.test(\"Response matches JSON schema\", () => {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
              "});\r",
              "\r",
              "pm.test(\"Successful POST request\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 202]);\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
