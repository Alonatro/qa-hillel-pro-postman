  "item": [
    {
      "name": "Validation tests - Create a new user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let random = Math.floor(Math.random() * 100000);\r",
              "\r",
              "pm.environment.set(\"email\", \"test\" + random + \"@test.com\");\r",
              "pm.environment.set(\"password\", \"Qwerty12345\");\r",
              "\r",
              "let validationData = pm.collectionVariables.get(\"validationData\");\r",
              "if (!validationData) {\r",
              "    validationData = JSON.stringify( [{\r",
              "    name : \"empty name\",\r",
              "    date : \"\",\r",
              "    status : \"error\",\r",
              "    code : 400\r",
              "},\r",
              "{\r",
              "    name : \"short name\",\r",
              "    date : \"aa\",\r",
              "    status : \"error\",\r",
              "    code : 400\r",
              "},\r",
              "{\r",
              "    name : \"long name\",\r",
              "    date : \"aaaaaaaaaaaaaaaaaaaaaa\",\r",
              "    status : \"error\",\r",
              "    code : 400\r",
              "},\r",
              "{\r",
              "    name : \"invalid name\",\r",
              "    date : \"ффф\",\r",
              "    status : \"error\",\r",
              "    code : 400\r",
              "},\r",
              "{\r",
              "    name : \"invalid name\",\r",
              "    date : \"*****\",\r",
              "    status : \"error\",\r",
              "    code : 400\r",
              "}\r",
              "]);\r",
              "\r",
              "pm.collectionVariables.set(\"validationData\", validationData);\r",
              "}\r",
              "\r",
              "let index = parseInt(pm.collectionVariables.get(\"currentIndex\") || \"0\");\r",
              "\r",
              "if (index < JSON.parse(validationData).length) {\r",
              "    const currentTest = JSON.parse(validationData)[index];\r",
              "    pm.variables.set(\"currentName\", currentTest.name);\r",
              "    pm.variables.set(\"currentDate\", currentTest.date);\r",
              "    pm.variables.set(\"expectedStatus\", currentTest.status);\r",
              "    pm.variables.set(\"expectedCode\", currentTest.code);\r",
              "    console.log(`Preparing negative test ${index}: ${currentTest.name}`);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var testData = JSON.parse(pm.collectionVariables.get(\"validationData\") || \"[]\");\r",
              "var index = parseInt(pm.collectionVariables.get(\"currentIndex\") || 0);\r",
              "\r",
              "if (index < testData.length) {\r",
              "    const currentTest = testData[index];\r",
              "\r",
              "    console.log(`Running negative test ${index}: ${currentTest.name}`);\r",
              "    console.log(`Expected code: ${currentTest.code}, Response code: ${pm.response.code}`);\r",
              "    \r",
              "    pm.test(\"Status code test: \" + currentTest.name, () => {\r",
              "        pm.expect(pm.response.code).to.eql(currentTest.code);\r",
              "    });\r",
              "\r",
              "    const body = pm.response.text() ? JSON.parse(pm.response.text()) : {};\r",
              "    if (body.status) {\r",
              "        console.log(`Expected status: ${currentTest.status}, Response status: ${body.status}`);\r",
              "        pm.test(\"Status field test: \" + currentTest.name, () => {\r",
              "            pm.expect(body.status).to.eql(currentTest.status);\r",
              "        });\r",
              "    }\r",
              "\r",
              "    pm.collectionVariables.set(\"currentIndex\", index + 1);\r",
              "    pm.execution.setNextRequest(pm.info.requestName);\r",
              "} else {\r",
              "    console.log(\"All negative tests completed, moving to Positive request\");\r",
              "    pm.collectionVariables.unset(\"currentIndex\");\r",
              "    pm.execution.setNextRequest(\"Create a new user\");\r",
              "}\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{currentName}}\",\r\n  \"lastName\": \"{{$randomLastName}}\",\r\n  \"email\": \"{{email}}\",\r\n  \"password\": \"{{password}}\",\r\n  \"repeatPassword\": \"{{password}}\"\r\n}",
          "options": {
