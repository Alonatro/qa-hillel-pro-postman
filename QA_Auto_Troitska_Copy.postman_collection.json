              "    pm.expect(response.data.totalCost).to.eql(parseInt(pm.environment.get(\"totalCost\")));\r",
              "});\r",
              "\r",
              "console.log(`Expense created: ID=${response.data.id}, TotalCost=${response.data.totalCost}, Date=${pm.environment.get(\"reportedAt\")}`);\r",
